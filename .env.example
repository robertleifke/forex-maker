# Server
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=info

# Database
DB_PATH=./data/cngn.db

# Security
KEY_ENCRYPTION_KEY=        # 32+ char secret for encrypted keys file
DASHBOARD_API_TOKEN=       # Token for dashboard auth

# RPC endpoints
BASE_RPC_URL=https://mainnet.base.org
BSC_RPC_URL=https://bsc-dataseed.binance.org

# Encrypted keys file path
KEYS_FILE=./keys.encrypted.json

# Optional notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Scheduler intervals (seconds)
PRICE_UPDATE_INTERVAL=30
POSITION_SYNC_INTERVAL=60
DEX_CHECK_INTERVAL=120
CEX_SYNC_INTERVAL=300
RATE_SYNC_INTERVAL=300
REBALANCE_CHECK_INTERVAL=120

# Trading parameters
TARGET_DELTA_RATIO=0.5
REBALANCE_THRESHOLD_PERCENT=5
