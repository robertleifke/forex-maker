# ── Server ────────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./data/cngn.db

# ── RPC endpoints ─────────────────────────────────────────────────────────────
# Set ALCHEMY_KEY to use Alchemy for all chains (recommended).
# Individual URLs are derived automatically; override only if needed
ALCHEMY_KEY=
BASE_RPC_URL=https://mainnet.base.org        # overridden by ALCHEMY_KEY if set
BSC_RPC_URL=https://bsc-dataseed.binance.org # overridden by ALCHEMY_KEY if set
ETH_RPC_URL=https://eth.llamarpc.com         # overridden by ALCHEMY_KEY if set

# ── Venue API keys ────────────────────────────────────────────────────────────
QUIDAX_API_KEY=
BLOCKRADAR_API_KEY=
BLOCKRADAR_WALLET_ID=
BLOCKRADAR_DEPOSIT_ADDRESS=

# ── Dashboard auth ────────────────────────────────────────────────────────────
DASHBOARD_API_TOKEN=

# ── HD Wallet ─────────────────────────────────────────────────────────────────
WALLET_MNEMONIC=
USE_TEST_ACCOUNTS=false

# ── Token contract addresses ──────────────────────────────────────────────────
# Defaults are correct — only override if the contract is redeployed.
CNGN_BASE_ADDRESS=0x46C85152bFe9f96829aA94755D9f915F9B10EF5F
USDC_BASE_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
USDT_BASE_ADDRESS=0xfde4C96c8593536E31F229EA8f37b2ADa2699bb2
CNGN_BSC_ADDRESS=0xa8aea66b361a8d53e8865c62d142167af28af058
USDT_BSC_ADDRESS=0x55d398326f99059fF775485246999027B3197955
USDT_ETH_ADDRESS=0xdAC17F958D2ee523a2206206994597C13D831ec7

# ── Aerodrome contract addresses (Base) ───────────────────────────────────────
AERODROME_POOL_ADDRESS=0x0206B696a410277eF692024C2B64CcF4EaC78589
AERODROME_NFT_MANAGER_ADDRESS=0x827922686190790b37229fd06084350E74485b72
AERODROME_ROUTER_ADDRESS=0xBE6D8f0d05cC4be24d5167a3eF062215bE6D18a5

# ── PancakeSwap contract addresses (BSC) ──────────────────────────────────────
PANCAKESWAP_POOL_ADDRESS=0xb84e7c912a1034ad674bba8859fca84f1f614a29
PANCAKESWAP_NFT_MANAGER_ADDRESS=0x46A15B0b27311cedF172AB29E4f4766fbE7F4364
PANCAKESWAP_ROUTER_ADDRESS=0x13f4EA83D0bd40E75C8222255bc855a974568Dd4

# ── Arbitrage ─────────────────────────────────────────────────────────────────
ARBITRAGE_ENABLED=true
ARBITRAGE_EXECUTION_ENABLED=false
ARBITRAGE_SCAN_INTERVAL=30
ARBITRAGE_MIN_SPREAD_BPS=150
ARBITRAGE_MIN_NET_PROFIT_BPS=50
ARBITRAGE_MAX_SINGLE_TRADE_USD=1000
ARBITRAGE_MAX_DAILY_VOLUME_USD=10000

# ── Scheduler intervals (seconds) ─────────────────────────────────────────────
PRICE_UPDATE_INTERVAL=30
POSITION_SYNC_INTERVAL=60
DEX_CHECK_INTERVAL=120
CEX_SYNC_INTERVAL=300
REBALANCE_CHECK_INTERVAL=120

# ── Optional notifications ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
