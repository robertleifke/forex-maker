# ── RPC endpoints ─────────────────────────────────────────────────────────────
# Set ALCHEMY_KEY to use Alchemy for all chains (recommended for production).
# Individual URLs fall back to public nodes if ALCHEMY_KEY is not set.
ALCHEMY_KEY=
# BASE_RPC_URL=https://mainnet.base.org        # overridden by ALCHEMY_KEY if set
# BSC_RPC_URL=https://bsc-dataseed.binance.org # overridden by ALCHEMY_KEY if set
# ETH_RPC_URL=https://eth.llamarpc.com         # overridden by ALCHEMY_KEY if set

# ── Venue API keys ────────────────────────────────────────────────────────────
QUIDAX_API_KEY=
QUIDAX_USER_ID=me
QUIDAX_TRADE_ADDRESS=
QUIDAX_LP_API_KEY=
QUIDAX_LP_USER_ID=me
QUIDAX_LP_ADDRESS=
BLOCKRADAR_API_KEY=
BLOCKRADAR_WALLET_ID=
BLOCKRADAR_DEPOSIT_ADDRESS=

# ── HD Wallet ─────────────────────────────────────────────────────────────────
# WALLET_MNEMONIC=       # Only set in production
USE_TEST_ACCOUNTS=true   # set true for local Anvil dev

# ── Direct API access ─────────────────────────────────────────────────────────
# Protects mutating API endpoints (curl/scripts). The Telegram bot is the
# primary operator interface and does not use this token.
ENGINE_API_TOKEN=        # any: openssl rand -hex 32

# ── Telegram operator bot ─────────────────────────────────────────────────────
# All mutating operations (pause, withdraw, shutdown) go through the TG bot.
# Dashboard is read-only and requires no token.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=        # group chat ID (negative integer)
