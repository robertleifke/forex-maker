# ── RPC endpoints ─────────────────────────────────────────────────────────────
# Set ALCHEMY_KEY to use Alchemy for all chains (recommended for production).
# Individual URLs fall back to public nodes if ALCHEMY_KEY is not set.
ALCHEMY_KEY=
# BASE_RPC_URL=https://mainnet.base.org        # overridden by ALCHEMY_KEY if set
# BSC_RPC_URL=https://bsc-dataseed.binance.org # overridden by ALCHEMY_KEY if set
# ETH_RPC_URL=https://eth.llamarpc.com         # overridden by ALCHEMY_KEY if set

# ── Venue API keys ────────────────────────────────────────────────────────────
QUIDAX_API_KEY=
QUIDAX_USER_ID=me
QUIDAX_TRADE_ADDRESS=
QUIDAX_LP_USER_ID=me
QUIDAX_LP_ADDRESS=
BLOCKRADAR_API_KEY=
BLOCKRADAR_WALLET_ID=
BLOCKRADAR_DEPOSIT_ADDRESS=

# ── StablesRail (Strails) ─────────────────────────────────────────────────────
# cNGN FX orderbook (https://docs.strails.co). beta.stablesrail.io/v1 is the
# LIVE production environment despite the name.
STRAILS_API_KEY=
# StablesRail enforces an IP allowlist. The deploy VPS's static IP is
# allowlisted; dev machines have rotating IPs and must tunnel through it:
#   ssh -D 1080 <vps>   then set:
# STRAILS_PROXY=socks5://localhost:1080
# Leave empty on the VPS itself. Scoped to StablesRail calls only — do NOT
# use HTTPS_PROXY, which would route Quidax and RPC traffic through the
# tunnel too.
STRAILS_PROXY=
# Smart wallet (StablesRail-assigned, on Base) that trades debit, and the
# registered external wallet that receives settled tokens. Both required to
# enable the strails venue.
STRAILS_SMART_WALLET_ADDRESS=
STRAILS_DESTINATION_WALLET=

# ── HD Wallet ─────────────────────────────────────────────────────────────────
# WALLET_MNEMONIC=       # Only set in production
USE_TEST_ACCOUNTS=true   # set true for local Anvil dev

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. For local dev add http://localhost:3000.
ALLOWED_ORIGINS=http://localhost:3000

# ── Quidax webhook ────────────────────────────────────────────────────────────
# Comma-separated source IP(s) allowed to call the unauthenticated Quidax webhook.
# Empty = fails closed (rejects everything). Set to your Quidax webhook source IP.
QUIDAX_WEBHOOK_ALLOWED_IPS=

# ── API token ─────────────────────────────────────────────────────────────────
# Protects mutating endpoints (pause, withdraw, shutdown, etc).
# Used by Telegram bot and operator scripts only — never expose to the frontend.
ENGINE_API_TOKEN=        # any: openssl rand -hex 32

# ── Telegram operator bot ─────────────────────────────────────────────────────
# All mutating operations (pause, withdraw, shutdown) go through the TG bot.
# Dashboard is read-only and requires no token.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=        # group chat ID (negative integer)

# ── Deployment (docker-compose + nginx-proxy) ─────────────────────────────────
# Public domain the engine is served on. Consumed by the nginx-proxy +
# acme-companion stack (see docker-compose.yml) to generate the vhost and
# Let's Encrypt certificate. Only needed when deploying behind nginx-proxy.
VIRTUAL_HOST=
LETSENCRYPT_HOST=
LETSENCRYPT_EMAIL=
