# Public ingress for the cNGN dashboard/API.
#
# The engine listens on 127.0.0.1:8000 (see docker-compose.yml); Caddy is the
# only public entry point and fetches/renews a Let's Encrypt certificate for the
# hostname automatically. WebSocket (/ws) upgrades are proxied transparently.
#
# The dashboard and all GET endpoints are public and read-only. Mutating routes
# are gated by ENGINE_API_TOKEN inside the app. The one exception is the Quidax
# webhook, which is unauthenticated and mutates in-memory order state — so it is
# locked to the server's own public IP here. IP filtering must live at this layer
# because Caddy sees the true TCP peer; an in-app check would have to trust a
# spoofable X-Forwarded-For header.

cngn.lavavc.io {
	@quidax_webhook_blocked {
		path /api/webhooks/quidax
		not remote_ip 77.42.32.180
	}
	respond @quidax_webhook_blocked 403

	reverse_proxy 127.0.0.1:8000
}
